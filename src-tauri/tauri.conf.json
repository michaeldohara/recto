{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Recto",
  "version": "1.0.1",
  "identifier": "com.michaeldohara.recto",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Recto",
        "width": 1040,
        "height": 720,
        "minWidth": 560,
        "minHeight": 420,
        "backgroundColor": "#F6F0E3",
        "decorations": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Michael O'Hara",
    "copyright": "Copyright (c) 2026 Michael O'Hara",
    "category": "Productivity",
    "shortDescription": "Viewer-first document reader for Windows",
    "longDescription": "A fast, viewer-first document reader. Open .md, .docx, .json, or .xml files from File Explorer, see them rendered, pretty-printed, or memo-styled, and export clean PDF, HTML, or Markdown — without the editor chrome of Word, Obsidian, Typora, or VS Code.",
    "licenseFile": "../LICENSE",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "mdx"],
        "name": "Markdown",
        "description": "Markdown document",
        "role": "Viewer",
        "mimeType": "text/markdown"
      },
      {
        "ext": ["docx"],
        "name": "Word",
        "description": "Word document",
        "role": "Viewer",
        "mimeType": "application/vnd.openxmlformats-officedocument.wordprocessingml.document"
      },
      {
        "ext": ["json"],
        "name": "JSON",
        "description": "JSON document",
        "role": "Viewer",
        "mimeType": "application/json"
      },
      {
        "ext": ["xml", "xsd", "xsl", "xslt", "rss", "atom"],
        "name": "XML",
        "description": "XML document",
        "role": "Viewer",
        "mimeType": "application/xml"
      }
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installMode": "currentUser",
        "languages": ["English"],
        "installerHooks": "installer/recto-hooks.nsh"
      }
    }
  }
}

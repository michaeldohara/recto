{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Recto",
  "version": "0.1.0",
  "identifier": "com.michaeldohara.recto",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Recto",
        "width": 1040,
        "height": 720,
        "minWidth": 560,
        "minHeight": 420,
        "backgroundColor": "#F6F0E3",
        "decorations": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
